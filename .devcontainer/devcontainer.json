{
  "name": "GPU Dev Container",

  // Use the pre-built image from GitHub Container Registry.
  // To build and push: docker build -t ghcr.io/curiousjaki/gpu-devcontainer:latest . && docker push ghcr.io/curiousjaki/gpu-devcontainer:latest
  "image": "ghcr.io/curiousjaki/gpu-devcontainer:latest",

  // GPU access
  "hostRequirements": {
    "gpu": "optional"
  },
  "runArgs": [
    "--gpus=all"
  ],

  // VS Code customizations
  "customizations": {
    "vscode": {
      "settings": {
        "editor.formatOnSave": true,
        "editor.tabSize": 4,
        "editor.insertSpaces": true,
        "editor.rulers": [88],
        "python.defaultInterpreterPath": "/usr/bin/python3",
        "python.formatting.provider": "black",
        "[python]": {
          "editor.defaultFormatter": "ms-python.black-formatter"
        },
        "terminal.integrated.defaultProfile.linux": "bash",
        "files.trimTrailingWhitespace": true,
        "files.insertFinalNewline": true
      },
      "extensions": [
        "ms-python.python",
        "ms-python.black-formatter",
        "ms-python.pylint",
        "ms-toolsai.jupyter",
        "ms-toolsai.vscode-jupyter-cell-tags",
        "ms-toolsai.jupyter-renderers",
        "nvidia.nsight-vscode-edition"
      ]
    }
  },

  // Uncomment to forward specific ports from the container
  // "forwardPorts": [8888],

  // Run as non-root user if one is configured in the image
  // "remoteUser": "vscode",

  "postCreateCommand": "python3 --version && nvidia-smi || echo 'No GPU available'"
}
